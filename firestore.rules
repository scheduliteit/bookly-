rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        (request.auth.token.email != null && request.auth.token.email.lower() == 'm.elsalameen@gmail.com') ||
        (request.auth.token.email != null && request.auth.token.email.lower() == 'scheduliteit@gmail.com') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      let isMasterAdmin = data.email == 'm.elsalameen@gmail.com' || request.auth.token.email == 'm.elsalameen@gmail.com';
      return data.id is string && data.id == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             (!('role' in data) || data.role == 'user' || (data.role == 'admin' && isMasterAdmin)) && 
             (!('subscriptionPlan' in data) || data.subscriptionPlan in ['basic', 'premium']);
    }

    function isValidClient(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 256;
    }

    function isValidAppointment(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             (!('clientId' in data) || data.clientId is string) &&
             data.date is string && data.date.size() <= 16 &&
             (!('time' in data) || data.time is string) &&
             data.status in ['confirmed', 'pending', 'cancelled', 'completed'];
    }

    function isValidFeedback(data) {
      return data.userId is string &&
             data.type in ['bug', 'feature', 'improvement', 'other'] &&
             data.message is string && data.message.size() <= 2000 &&
             data.createdAt is timestamp;
    }

    function isValidPublicAppointment(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.date is string && data.date.size() <= 16 &&
             data.status in ['pending', 'confirmed'];
    }

    // --- Rules ---

    // /users/{userId}
    match /users/{userId} {
      allow get: if true; // Allow public lookups for business details
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'businessName', 'businessCategory', 'services', 'connectedApps', 'legalData', 'currency', 'onboardingCompleted', 'timezone', 'workingHours', 'loginCount', 'lastLoginAt', 'lastSeenAt', 'reminderSettings', 'language', 'subscriptionPlan'])) ||
        ((request.auth.token.email == 'm.elsalameen@gmail.com' || request.auth.token.email == 'scheduliteit@gmail.com') && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'businessName', 'businessCategory', 'services', 'connectedApps', 'legalData', 'currency', 'onboardingCompleted', 'timezone', 'workingHours', 'role', 'subscriptionPlan', 'loginCount', 'lastLoginAt', 'lastSeenAt', 'reminderSettings', 'language']))
      );
      allow delete: if false; 
    }

    // /public_profiles/{userId}
    match /public_profiles/{userId} {
      allow read: if true; 
      allow write: if isOwner(userId); 
    }

    // /clients/{clientId}
    match /clients/{clientId} {
      allow list: if true; 
      allow get: if true; 
      allow create: if true; 
      allow update: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid) || (!isSignedIn());
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid) || (!isSignedIn());
    }

    // /appointments/{appointmentId}
    match /appointments/{appointmentId} {
      allow list: if true; 
      allow get: if true; 
      allow create: if true; 
      allow update: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid) || (!isSignedIn());
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid) || (!isSignedIn());
    }

    // /feedback/{feedbackId}
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
