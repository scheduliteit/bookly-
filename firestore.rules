rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        request.auth.token.email == 'scheduliteit@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      let isMasterAdmin = data.email == 'scheduliteit@gmail.com' || (request.auth.token.email == 'scheduliteit@gmail.com');
      return data.id is string && data.id == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             (!('role' in data) || data.role == 'user' || (data.role == 'admin' && isMasterAdmin)) && 
             (!('subscriptionPlan' in data) || data.subscriptionPlan in ['basic', 'premium']);
    }

    function isValidClient(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 128 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 128));
    }

    function isValidAppointment(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.clientId is string &&
             data.date is string && data.date.size() <= 16 &&
             data.status in ['confirmed', 'pending', 'cancelled', 'completed'];
    }

    // --- Rules ---

    // /users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'businessName', 'businessCategory', 'services', 'connectedApps', 'legalData', 'currency', 'onboardingCompleted', 'timezone', 'workingHours'])) ||
        (request.auth.token.email == 'scheduliteit@gmail.com' && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'businessName', 'businessCategory', 'services', 'connectedApps', 'legalData', 'currency', 'onboardingCompleted', 'timezone', 'workingHours', 'role', 'subscriptionPlan']))
      );
      allow delete: if false; // Profiles are rarely deleted via client
    }

    // /public_profiles/{userId}
    match /public_profiles/{userId} {
      allow read: if true; // Public access
      allow write: if isOwner(userId); // Simplified but relies on User owner
    }

    // /clients/{clientId}
    match /clients/{clientId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidClient(incoming()) && isValidId(clientId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidClient(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'notes', 'lastVisit']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // /appointments/{appointmentId}
    match /appointments/{appointmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidAppointment(incoming()) && isValidId(appointmentId);
      allow update: if (isSignedIn() && existing().userId == request.auth.uid && isValidAppointment(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['date', 'time', 'status', 'reminderSent'])) || isAdmin();
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
