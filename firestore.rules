rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true || 
        request.auth.token.email == 'm.elsalameen@gmail.com' ||
        request.auth.token.email == 'scheduliteit@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      let isMasterAdmin = data.email == 'm.elsalameen@gmail.com' || data.email == 'scheduliteit@gmail.com' || (request.auth.token.email == 'm.elsalameen@gmail.com' || request.auth.token.email == 'scheduliteit@gmail.com');
      return data.id is string && data.id == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             (!('role' in data) || data.role == 'user' || (data.role == 'admin' && isMasterAdmin)) && 
             (!('subscriptionPlan' in data) || data.subscriptionPlan in ['basic', 'premium']);
    }

    function isValidClient(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 128 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 128));
    }

    function isValidAppointment(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.clientId is string &&
             data.date is string && data.date.size() <= 16 &&
             data.status in ['confirmed', 'pending', 'cancelled', 'completed'];
    }

    function isValidFeedback(data) {
      return data.userId is string &&
             data.type in ['bug', 'feature', 'improvement', 'other'] &&
             data.message is string && data.message.size() <= 2000 &&
             data.createdAt is timestamp;
    }

    function isValidPublicAppointment(data) {
      return data.userId is string &&
             data.clientId is string &&
             data.date is string && data.date.size() <= 16 &&
             data.time is string &&
             data.status == 'pending';
    }

    // --- Rules ---

    // /users/{userId}
    match /users/{userId} {
      allow get: if true; // Allow public lookups for business details
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'businessName', 'businessCategory', 'services', 'connectedApps', 'legalData', 'currency', 'onboardingCompleted', 'timezone', 'workingHours', 'loginCount', 'lastLoginAt'])) ||
        ((request.auth.token.email == 'm.elsalameen@gmail.com' || request.auth.token.email == 'scheduliteit@gmail.com') && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'businessName', 'businessCategory', 'services', 'connectedApps', 'legalData', 'currency', 'onboardingCompleted', 'timezone', 'workingHours', 'role', 'subscriptionPlan', 'loginCount', 'lastLoginAt']))
      );
      allow delete: if false; 
    }

    // /public_profiles/{userId}
    match /public_profiles/{userId} {
      allow read: if true; 
      allow write: if isOwner(userId); 
    }

    // /clients/{clientId}
    match /clients/{clientId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if (isSignedIn() && isValidClient(incoming())) || (!isSignedIn() && incoming().userId != null); 
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidClient(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'notes', 'lastVisit']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // /appointments/{appointmentId}
    match /appointments/{appointmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if (isSignedIn() && isValidAppointment(incoming())) || (!isSignedIn() && isValidPublicAppointment(incoming()));
      allow update: if (isSignedIn() && existing().userId == request.auth.uid && isValidAppointment(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['date', 'time', 'status', 'reminderSent'])) || isAdmin();
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // /feedback/{feedbackId}
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
