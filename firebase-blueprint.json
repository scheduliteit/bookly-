{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and business settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "businessName": { "type": "string" },
        "businessCategory": { "type": "string" },
        "onboarded": { "type": "boolean" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "duration": { "type": "number" },
              "description": { "type": "string" },
              "bufferTime": { "type": "number" },
              "color": { "type": "string" }
            }
          }
        },
        "connectedApps": {
          "type": "array",
          "items": { "type": "string" }
        },
        "legalData": {
          "type": "object",
          "properties": {
            "privacyPolicy": { "type": "string" },
            "termsOfService": { "type": "string" },
            "gdprStrict": { "type": "boolean" }
          }
        },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "ILS"] },
        "subscriptionPlan": { "type": "string", "enum": ["basic", "premium"] }
      },
      "required": ["id", "email"]
    },
    "Client": {
      "title": "Client",
      "description": "Client information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "lastVisit": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "name"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Appointment details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "service": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "duration": { "type": "number" },
        "status": { "type": "string", "enum": ["confirmed", "pending", "cancelled", "completed"] },
        "price": { "type": "number" },
        "reminderSent": { "type": "boolean" },
        "reminderTimestamp": { "type": "string" }
      },
      "required": ["id", "userId", "clientId", "date", "time"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Publicly visible business information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "businessName": { "type": "string" },
        "businessCategory": { "type": "string" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "duration": { "type": "number" },
              "description": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "currency": { "type": "string" },
        "legalData": {
          "type": "object",
          "properties": {
            "privacyPolicy": { "type": "string" },
            "termsOfService": { "type": "string" },
            "gdprStrict": { "type": "boolean" }
          }
        }
      },
      "required": ["userId", "businessName"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback or bug reports",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "type": { "type": "string", "enum": ["bug", "feature", "improvement", "other"] },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "reviewed", "resolved"] }
      },
      "required": ["userId", "type", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings"
    },
    "/public_profiles/{userId}": {
      "schema": "PublicProfile",
      "description": "Publicly visible business information"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Clients managed by the user"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments scheduled by the user"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Platform feedback and bug reports"
    }
  }
}
